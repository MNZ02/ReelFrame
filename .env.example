# Postgres
DATABASE_URL=postgres://higgsfield:higgsfield@localhost:55432/higgsfield

# MinIO / S3
S3_ENDPOINT=http://localhost:59000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=media
S3_REGION=us-east-1
# Optional: publicly reachable base URL for MinIO, used only for source-image
# URLs handed to a cloud video provider (which can't reach localhost). Set to
# a tunnel URL, e.g. `cloudflared tunnel --url http://localhost:59000` then
# paste the https://<name>.trycloudflare.com URL here. Required for
# image-to-video with fal/replicate; leave empty for text-to-video or mock.
S3_PUBLIC_ENDPOINT=

# better-auth
BETTER_AUTH_SECRET=dev-secret-change-me-please-32chars-min
BETTER_AUTH_URL=http://localhost:4000

# Google OAuth (optional, off unless both are set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Video generation
VIDEO_PROVIDER=mock
FAL_KEY=
# Required only when VIDEO_PROVIDER=replicate (minimax/video-01, free-run tier)
REPLICATE_API_TOKEN=

# Prompt enhancement. "rule" (default) = deterministic in-repo builder, no key.
# "llm" additionally rewrites the prompt via an OpenAI-compatible chat API and
# needs LLM_API_KEY; falls back to rule-based on any error.
PROMPT_ENHANCER=rule
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3.5-haiku

# Ports / URLs
API_PORT=4000
WEB_URL=http://localhost:3000

# apps/web: base URL it calls the API on (browser-visible, must be NEXT_PUBLIC_*)
NEXT_PUBLIC_API_URL=http://localhost:4000
