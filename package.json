{
  "name": "higgsfield-clone",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:migrate": "bun run --filter=@repo/db migrate",
    "db:generate": "bun run --filter=@repo/db generate",
    "db:seed": "bun run --filter=api db:seed",
    "smoke": "bun run --filter=api smoke"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.3"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
