# The web app now lives on Vercel; the VM only fronts the API.
#
# `92-4-85-148.sslip.io` is a real DNS name that resolves to this VM's public
# IP (92.4.85.148), so Caddy can provision a Let's Encrypt certificate
# automatically — HTTP-01 challenge on :80, TLS served on :443. HTTPS is
# required because the cross-site session cookie is Secure and the browser
# won't send it to (or accept it from) a plaintext origin.
#
# When you get a real domain, replace the hostname below and set WEB_URL /
# NEXT_PUBLIC_API_URL accordingly.
92-4-85-148.sslip.io {
	reverse_proxy api:4000
}
