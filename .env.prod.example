# Production env for the single-VM stack (docker-compose.prod.yml).
# Copy to `.env` on the server and fill in. NEVER commit the real .env.
# Replace 92.4.85.148 with your VM's public IP (or domain).

# --- Postgres (internal; host is the compose service name) ---
POSTGRES_USER=higgsfield
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=higgsfield
DATABASE_URL=postgres://higgsfield:CHANGE_ME_db_password@postgres:5432/higgsfield

# --- MinIO / S3 (S3_ENDPOINT must be the PUBLIC address: browser + provider fetch from it) ---
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_minio_password
S3_BUCKET=media
S3_REGION=us-east-1
S3_ENDPOINT=http://92.4.85.148:9000
S3_PUBLIC_ENDPOINT=http://92.4.85.148:9000

# --- Auth (single origin via Caddy on :80) ---
BETTER_AUTH_SECRET=CHANGE_ME_random_32_plus_chars
BETTER_AUTH_URL=http://92.4.85.148
WEB_URL=http://92.4.85.148

# --- Video generation ---
VIDEO_PROVIDER=replicate
FAL_KEY=
REPLICATE_API_TOKEN=CHANGE_ME_replicate_token

# --- Prompt enhancement (rule-based needs no key) ---
PROMPT_ENHANCER=rule
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3.5-haiku

# --- Ports / URLs ---
API_PORT=4000
# Baked into the web bundle at build time; the app calls the API same-origin via Caddy.
NEXT_PUBLIC_API_URL=http://92.4.85.148
