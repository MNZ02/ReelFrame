# Production env for the single-VM stack (docker-compose.prod.yml).
# Copy to `.env` on the server and fill in. NEVER commit the real .env.
# Replace 92.4.85.148 with your VM's public IP (or domain).

# --- Postgres (internal; host is the compose service name) ---
POSTGRES_USER=higgsfield
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=higgsfield
DATABASE_URL=postgres://higgsfield:CHANGE_ME_db_password@postgres:5432/higgsfield

# --- MinIO / S3 ---
# S3_ENDPOINT is INTERNAL (docker service name) — the API/worker talk to MinIO
# directly on the compose network. S3_PUBLIC_ENDPOINT is the browser/provider-
# facing HTTPS host, served by Caddy (deploy/Caddyfile) so presigned URLs are
# https and don't trip mixed-content blocking. (Interim until media → R2.)
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_minio_password
S3_BUCKET=media
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://s3.92-4-85-148.sslip.io

# --- Auth (web on Vercel, API on the VM — cross-site, so both must be HTTPS) ---
BETTER_AUTH_SECRET=CHANGE_ME_random_32_plus_chars
# The API's own public HTTPS origin (Caddy + sslip.io in deploy/Caddyfile).
BETTER_AUTH_URL=https://92-4-85-148.sslip.io
# The Vercel origin. Drives CORS (app.ts) + better-auth trustedOrigins. Must be
# the EXACT production URL — Vercel preview deploys have other URLs and won't auth.
WEB_URL=https://reel-frame-web.vercel.app

# --- Video generation ---
VIDEO_PROVIDER=replicate
FAL_KEY=
REPLICATE_API_TOKEN=CHANGE_ME_replicate_token

# --- Prompt enhancement (rule-based needs no key) ---
PROMPT_ENHANCER=rule
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-3.5-haiku

# --- Ports / URLs ---
API_PORT=4000
# NEXT_PUBLIC_API_URL is no longer set here — the web app builds on Vercel, where
# this env var is configured (= https://92-4-85-148.sslip.io) and baked at build.
